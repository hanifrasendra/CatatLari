<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/beranda"
    tools:context=".BerandaFragment"
    android:background="#F5F3F5">

    <ImageView
        android:id="@+id/imageView11"
        android:layout_width="248dp"
        android:layout_height="169dp"
        android:src="@drawable/run2"
        tools:layout_editor_absoluteX="278dp"
        tools:layout_editor_absoluteY="441dp" />

    <ImageView
        android:id="@+id/imageView10"
        android:layout_width="261dp"
        android:layout_height="166dp"
        android:src="@drawable/run1"
        tools:layout_editor_absoluteX="8dp"
        tools:layout_editor_absoluteY="441dp" />

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="366dp"
        android:layout_height="449dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="52dp"
        android:src="@drawable/bg1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView9"
        android:layout_width="224dp"
        android:layout_height="194dp"
        android:src="@drawable/fg1"
        tools:layout_editor_absoluteX="20dp"
        tools:layout_editor_absoluteY="177dp" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bubblegum_sans"
        android:text="Today's Popular Track"
        tools:layout_editor_absoluteX="20dp"
        tools:layout_editor_absoluteY="131dp"
        android:textSize="30sp"
        android:textColor="#1f7a8c"
        />

    <TextView
        android:id="@+id/textView13"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bubblegum_sans"
        android:text="Routes near you"
        android:textColor="#1f7a8c"
        android:textSize="20sp"
        tools:layout_editor_absoluteX="20dp"
        tools:layout_editor_absoluteY="409dp" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bubblegum_sans"
        android:text="Imperial Palace"
        android:textColor="#f5f3f5"
        android:textSize="20sp"
        tools:layout_editor_absoluteX="244dp"
        tools:layout_editor_absoluteY="221dp" />

    <TextView
        android:id="@+id/textView9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bubblegum_sans"
        android:text="Available Routes:"
        android:textColor="#f5f3f5"
        android:textSize="12sp"
        tools:layout_editor_absoluteX="244dp"
        tools:layout_editor_absoluteY="275dp" />

    <TextView
        android:id="@+id/textView12"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bubblegum_sans"
        android:text="> The Tokyo Tower"
        android:textColor="#f5f3f5"
        android:textSize="8sp"
        tools:layout_editor_absoluteX="244dp"
        tools:layout_editor_absoluteY="317dp" />

    <TextView
        android:id="@+id/textView10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bubblegum_sans"
        android:text="> Cherry Blossoms"
        android:textColor="#f5f3f5"
        android:textSize="8sp"
        tools:layout_editor_absoluteX="244dp"
        tools:layout_editor_absoluteY="297dp" />

    <TextView
        android:id="@+id/textView11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bubblegum_sans"
        android:text="> National Museum of Modern Art"
        android:textColor="#34e5dc"
        android:textSize="8sp"
        tools:layout_editor_absoluteX="244dp"
        tools:layout_editor_absoluteY="307dp" />

    <TextView
        android:id="@+id/textView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bubblegum_sans"
        android:text="4 Km"
        android:textColor="#34e5dc"
        android:textSize="12sp"
        tools:layout_editor_absoluteX="244dp"
        tools:layout_editor_absoluteY="245dp" />

    <ImageView
        android:id="@+id/imageView4"
        android:layout_width="31dp"
        android:layout_height="38dp"
        android:layout_marginEnd="20dp"
        android:src="@drawable/profile"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout_editor_absoluteY="28dp" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="20dp"
        android:fontFamily="@font/bubblegum_sans"
        android:text="Halo, User!"
        android:textAlignment="textStart"
        android:textColor="#1f7a8c"
        android:textSize="40sp"
        android:transitionName="logo_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="643dp"
        android:fontFamily="@font/bubblegum_sans"
        android:text="Selamat datang di aplikasi CatatLari"
        android:textAlignment="textStart"
        android:textColor="#022b3a"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/floatinAddButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="40dp"
        android:backgroundTint="#34e5dc"
        android:clickable="true"
        android:src="@drawable/outline_add_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>


    <!--        android:src="@drawable/icon_plus"-->

</androidx.constraintlayout.widget.ConstraintLayout>